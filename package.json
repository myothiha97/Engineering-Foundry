{
  "name": "engineering-learning-platforms",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.15.1",
  "engines": {
    "node": ">=24.17.0"
  },
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "typecheck": "turbo typecheck",
    "lint": "turbo lint",
    "test": "turbo test",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "content:validate": "node --import tsx scripts/validate-content.ts",
    "db:generate": "pnpm --filter @platform/database db:generate",
    "db:migrate": "pnpm --filter @platform/database db:migrate",
    "db:seed": "pnpm --filter @platform/database db:seed",
    "e2e": "playwright test"
  },
  "devDependencies": {
    "@playwright/test": "^1.55.0",
    "prettier": "^3.6.2",
    "tsx": "^4.20.5",
    "turbo": "^2.5.6",
    "typescript": "^6.0.0",
    "vitest": "^3.2.4"
  }
}
